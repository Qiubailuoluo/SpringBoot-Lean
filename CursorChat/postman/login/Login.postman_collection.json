{
  "info": {
    "_postman_id": "b2c4e6d8-1a3b-5e7f-9a0b-1c2d3e4f5a6b",
    "name": "Login Module API (JWT + Redis)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Verification - Send",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"verification send success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "var body = pm.response.json();",
              "if (body && body.data && body.data.code) {",
              "    pm.collectionVariables.set(\"verifyCode\", body.data.code);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target\": \"demo@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/verification/send",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "verification",
            "send"
          ]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"login success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "var body = pm.response.json();",
              "if (body && body.data) {",
              "    pm.collectionVariables.set(\"accessToken\", body.data.token || \"\");",
              "    pm.collectionVariables.set(\"refreshToken\", body.data.refreshToken || \"\");",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{oldPassword}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"refresh success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "var body = pm.response.json();",
              "if (body && body.data && body.data.token) {",
              "    pm.collectionVariables.set(\"accessToken\", body.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      }
    },
    {
      "name": "Change Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"change password success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"{{oldPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/password/change",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "password",
            "change"
          ]
        }
      }
    },
    {
      "name": "Reset Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"reset password success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"verifyTarget\": \"{{verifyTarget}}\",\n  \"verifyCode\": \"{{verifyCode}}\",\n  \"newPassword\": \"{{oldPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/password/reset",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "password",
            "reset"
          ]
        }
      }
    },
    {
      "name": "Audit - Verification Recent",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"audit query success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/audit/verification/recent?limit=20&target={{verifyTarget}}&success=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "audit",
            "verification",
            "recent"
          ],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "target",
              "value": "{{verifyTarget}}"
            },
            {
              "key": "success",
              "value": "true"
            }
          ]
        }
      }
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"logout success\", function () {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        }
      }
    }
  ],
